MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=student_agent_db
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://student-agent-api
ENVIRONMENT=demo
USE_MOCK_DATA=false

# ── LLM endpoints ────────────────────────────────────────────────────────────
# Single-endpoint (legacy, still supported as a fallback):
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/api/v1
LM_STUDIO_MODEL=qwen/qwen3.5-9b

# Multi-endpoint pool (overrides the two vars above when set).
# Format: base_url|model|roles  — endpoints separated by ';', roles by ','.
# Roles: classify | chat | agent.  Omit roles to serve all.
# Example — a fast model for classification, a strong model for chat/agents:
#   LM_STUDIO_ENDPOINTS=http://127.0.0.1:1234/api/v1|qwen/qwen3.5-9b|chat,agent;http://10.5.0.2:1234/api/v1|qwen/qwen3-1.7b|classify
# LM_STUDIO_ENDPOINTS=
LM_STUDIO_CONCURRENCY_PER_ENDPOINT=1

# Cloud fallback — used automatically only when NO local endpoint is reachable
# at startup. Leave ANTHROPIC_API_KEY blank to disable the fallback.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_CONCURRENCY=4
